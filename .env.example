# Authentification INSEE — https://portail-api.insee.fr/ (optionnel)
# Si souscription Melodi refusée : le pipeline utilise data.gouv (DVF, Caisse des Dépôts).
# Créez une application, puis utilisez l'une des deux options :

# Option A : jeton Bearer direct
INSEE_API_KEY=

# Option B : clé + secret consommateur (OAuth client_credentials)
INSEE_CONSUMER_KEY=
INSEE_CONSUMER_SECRET=

# Origines autorisées pour le dashboard (séparées par des virgules)
CORS_ORIGINS=http://localhost:8001,http://127.0.0.1:5500,http://localhost:5500

# Géocodage (BAN puis Nominatim) — adresses DVF sans coordonnées
GEOCODING_MAX_PER_ARR=5
NOMINATIM_DELAY_SEC=1.1
GEOCODING_USER_AGENT=UrbanDataExplorer/1.0 (contact@example.com)

# API locale (8001 par défaut — Docker/nginx peut utiliser 8000)
API_PORT=8001
API_HOST=0.0.0.0

# Plateforme data (RNCP) — docker compose up -d
UDE_DATA_ROOT=data
DATA_BACKEND=auto
POSTGRES_URL=postgresql://ude_admin:ude_admin_dev@localhost:5433/urban_data
POSTGRES_READER_URL=postgresql://ude_reader:ude_reader_dev@localhost:5433/urban_data
MONGO_URL=mongodb://localhost:27017
MONGO_DB=urban_data
MONGO_GEO_COLLECTION=geo_points
GEO_POINTS_MAX_PER_ARR=40
GEO_POINTS_MAX_GEOCODED=80
REDIS_URL=redis://localhost:6379/0
KAFKA_BOOTSTRAP_SERVERS=localhost:9094
KAFKA_TOPIC=ude.pipeline.events
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=ude_minio
MINIO_SECRET_KEY=ude_minio_secret
MINIO_SECURE=false

# Sécurité API (optionnel — vide = auth désactivée en local)
UDE_API_KEY=
API_RATE_LIMIT=120
API_RATE_WINDOW_SEC=60
